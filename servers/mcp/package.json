{
  "name": "@bighub/bighub-mcp",
  "version": "0.2.1",
  "mcpName": "io.bighub/mcp",
  "description": "MCP server for decision learning for AI agent actions with BIGHUB.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bighub-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "homepage": "https://bighub.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/bighub-io/bighub.git",
    "directory": "servers/mcp"
  },
  "bugs": {
    "url": "https://github.com/bighub-io/bighub/issues"
  },
  "keywords": [
    "bighub",
    "mcp",
    "model-context-protocol",
    "decision-learning",
    "ai-agents"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
